---
import MainLayout from "../../layouts/MainLayout.astro";
import Encabezado from "../../componentes/encabezado/Encabezado.astro";
import EncabezadoScroll from "../../componentes/encabezado/EncabezadoScroll.astro";
import MenuMovil from "../../componentes/encabezado/MenuMovil.astro";
import PiePagina from "../../componentes/pie-pagina/PiePagina.astro";
import NoticiasRuntime from "../../componentes/sistema/NoticiasRuntime.astro";
import ScriptsSitio from "../../componentes/sistema/ScriptsSitio.astro";
import { rutas } from "../../lib/rutas";
---

<MainLayout title="Admin Noticias | Escuela Esperanza">
  <Encabezado />
  <EncabezadoScroll />
  <MenuMovil />

  <main class="internal-page admin-page">
    <section class="internal-hero">
      <div class="internal-hero-content">
        <span class="internal-kicker">Administrador</span>
        <h1>Gestion de noticias</h1>
      </div>
    </section>

    <section class="admin-news-section">
      <div class="news-setup-state news-setup-state--page" data-admin-setup hidden></div>

      <section class="admin-auth-card" data-admin-auth-card>
        <h2>Ingreso administrador</h2>
        <p>
          Solo la cuenta administradora podra ingresar, crear, editar y eliminar
          noticias.
        </p>

        <form class="admin-login-form" data-admin-login-form>
          <label class="admin-field">
            <span>Correo administrador</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <label class="admin-field">
            <span>Contrasena</span>
            <input name="password" type="password" autocomplete="current-password" required />
          </label>

          <div class="admin-form-actions">
            <button type="submit" class="admin-primary-button">Ingresar</button>
          </div>
        </form>

        <p class="admin-login-message" data-admin-login-message></p>
      </section>

      <div data-admin-panel hidden>
        <div class="admin-news-toolbar">
          <h2>Panel de noticias</h2>
          <div class="admin-toolbar-actions">
            <a href={rutas.noticias} class="admin-secondary-link">Ver noticias publicadas</a>
            <button type="button" class="admin-secondary-link" data-admin-logout>
              Cerrar sesion
            </button>
          </div>
        </div>

        <div class="admin-status-box" data-admin-status hidden></div>

        <div class="admin-news-layout">
          <form class="admin-news-form" data-admin-news-form>
            <input type="hidden" data-news-id-input />

            <h3 data-admin-form-title>Subir nueva noticia</h3>

            <label class="admin-field">
              <span>Imagen de la noticia</span>
              <input data-news-image-input type="file" accept="image/*" />
            </label>

            <label class="admin-field">
              <span>Titulo de la noticia</span>
              <input
                data-news-title-input
                type="text"
                maxlength="140"
                placeholder="Escribe el titulo"
                required
              />
            </label>

            <label class="admin-field">
              <span>Texto de la noticia</span>
              <textarea
                data-news-content-input
                rows="10"
                placeholder="Escribe aqui el contenido completo de la noticia"
                required
              ></textarea>
            </label>

            <div class="admin-form-actions">
              <button type="submit" class="admin-primary-button">
                <span data-admin-submit-label>Subir nueva noticia</span>
              </button>

              <button type="button" class="admin-secondary-link" data-admin-cancel-edit hidden>
                Cancelar edicion
              </button>
            </div>
          </form>

          <aside class="admin-news-help">
            <h3>Vista previa estructural</h3>
            <p>
              Si el administrador no carga una imagen, el sistema usara una imagen
              predeterminada para representar la noticia.
            </p>

            <div class="admin-default-image-card">
              <img data-admin-preview-image src="/images/slide3.png" alt="Vista previa de noticia" />
              <div class="news-date-badge news-date-badge--page">
                <span class="news-date-icon">
                  <i class="fa-solid fa-book-open"></i>
                </span>
                <span class="news-date-text">21/04/2026</span>
              </div>
            </div>
          </aside>
        </div>

        <section class="admin-news-list-section">
          <div class="admin-news-list-header">
            <h2>Noticias cargadas</h2>
            <p>
              Aqui el administrador podra revisar, editar o eliminar las noticias
              publicadas.
            </p>
          </div>

          <div class="admin-news-list" data-admin-news-list></div>

          <div class="news-empty-state news-empty-state--page" data-admin-news-empty>
            <p>Aun no hay noticias creadas.</p>
          </div>
        </section>
      </div>
    </section>
  </main>

  <PiePagina />
  <NoticiasRuntime />
  <ScriptsSitio />
</MainLayout>
