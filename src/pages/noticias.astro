---
import MainLayout from "../layouts/MainLayout.astro";
import Encabezado from "../componentes/encabezado/Encabezado.astro";
import EncabezadoScroll from "../componentes/encabezado/EncabezadoScroll.astro";
import MenuMovil from "../componentes/encabezado/MenuMovil.astro";
import PiePagina from "../componentes/pie-pagina/PiePagina.astro";
import NoticiasRuntime from "../componentes/sistema/NoticiasRuntime.astro";
import ScriptsSitio from "../componentes/sistema/ScriptsSitio.astro";
import { rutas } from "../lib/rutas";
---

<MainLayout title="Noticias | Escuela Esperanza">
  <Encabezado />
  <EncabezadoScroll />
  <MenuMovil />

  <main class="internal-page">
    <section class="internal-hero">
      <div class="internal-hero-content">
        <span class="internal-kicker">Noticias</span>
        <h1>Todas las noticias</h1>
      </div>
    </section>

    <section class="news-page-section">
      <div class="news-page-header">
        <span class="home-news-kicker">Comunidad escolar</span>
        <h2>Actualidad y actividades de la Escuela Esperanza</h2>
        <p>
          Aqui cualquier persona que visite el sitio podra revisar las noticias
          publicadas por la administracion, conocer actividades recientes y ver
          los comunicados mas importantes.
        </p>
      </div>

      <div class="news-setup-state news-setup-state--page" data-news-public-setup hidden></div>

      <div class="news-page-list" data-news-public-list></div>

      <div class="news-empty-state news-empty-state--page" data-news-public-empty>
        <p>Todavia no hay noticias cargadas para mostrar al publico.</p>
        <a href={rutas.adminNoticias} class="home-news-button">Ir al panel admin</a>
      </div>
    </section>
  </main>

  <PiePagina />
  <NoticiasRuntime />
  <ScriptsSitio />
</MainLayout>
